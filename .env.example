# LLM provider compatible with OpenAI chat APIs.
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL_NAME=gpt-4o-mini

# Kingsoft Cloud credentials. Required for deploy and optional cloud KB/LTM modes.
KSYUN_ACCESS_KEY=
KSYUN_SECRET_KEY=

# Optional Kingsoft Cloud knowledge base mode.
# Leave KSADK_KB_DATASET_ID empty to use local sample corpus in RAG demos.
KSADK_KB_DATASET_ID=
KSADK_KB_ENDPOINT=aicp.api.ksyun.com
KSADK_KB_REGION=cn-beijing-6
KSADK_KB_SCHEME=https

# Optional long-term memory mode.
# The memory demos work with local process memory by default.
KSADK_LTM_BACKEND=
KSADK_LTM_INDEX=ksadk_samples

